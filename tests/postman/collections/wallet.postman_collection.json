        {"name":"7.4 adjust DEBIT exceeds balance → 400 (Wallet PDF Decision 4.1)","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('400 InsufficientBalance',()=>pm.response.to.have.status(400));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{user_jwt_admin}}"},{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"k-adj-over-{{$timestamp}}"}],"body":{"mode":"raw","raw":"{\"amountCents\":99999999,\"direction\":\"DEBIT\",\"memo\":\"force overdraft probe\"}"},"url":{"raw":"{{wallet_url}}/api/admin/wallet/{{alice_user_id}}/adjust","host":["{{wallet_url}}"],"path":["api","admin","wallet","{{alice_user_id}}","adjust"]}}},
        {"name":"7.5 adjust missing memo → 400 (@NotBlank)","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('400',()=>pm.response.to.have.status(400));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{user_jwt_admin}}"},{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"k-adj-nomemo-{{$timestamp}}"}],"body":{"mode":"raw","raw":"{\"amountCents\":100,\"direction\":\"CREDIT\"}"},"url":{"raw":"{{wallet_url}}/api/admin/wallet/{{alice_user_id}}/adjust","host":["{{wallet_url}}"],"path":["api","admin","wallet","{{alice_user_id}}","adjust"]}}},
