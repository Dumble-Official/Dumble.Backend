    {
      "name": "6. /wallet/me/withdrawals lifecycle",
      "item": [
        {"name":"6.0 setup: top up alice with enough to withdraw","event":[{"listen":"prerequest","script":{"type":"text/javascript","exec":["pm.environment.set('topup_idem','k-topup-{{run_stamp}}');"]}},{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('topup 201',()=>pm.response.to.have.status(201));","pm.environment.set('alice_balance_pre_withdrawal',pm.response.json().newBalanceCents);"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{system_jwt_service}}"},{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"{{topup_idem}}"}],"body":{"mode":"raw","raw":"{\"userId\":\"{{alice_user_id}}\",\"amountCents\":50000,\"source\":\"CHARGEBACK\",\"externalRef\":\"topup-{{run_stamp}}\"}"},"url":{"raw":"{{wallet_url}}/api/wallet/credit","host":["{{wallet_url}}"],"path":["api","wallet","credit"]}}},
        {"name":"6.1 POST /withdrawals 10000 cents → 201, status in active lifecycle","event":[{"listen":"prerequest","script":{"type":"text/javascript","exec":["pm.environment.set('w_idem','k-w-{{run_stamp}}-1');"]}},{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('201',()=>pm.response.to.have.status(201));","const j=pm.response.json();","// Dev stub responds synchronously, so by the time we get this 201 Wallet has","// already flipped from PENDING → SUBMITTING → SENT in one tick. All three","// are valid lifecycle states before a webhook arrives.","pm.test('status in active set',()=>pm.expect(['PENDING','SUBMITTING','SENT']).to.include(j.status));","pm.environment.set('w_id',j.id);"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{user_jwt_alice}}"},{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"{{w_idem}}"}],"body":{"mode":"raw","raw":"{\"amountCents\":10000,\"destination\":{\"type\":\"bank\",\"iban\":\"EG800000000000000000000001\"}}"},"url":{"raw":"{{wallet_url}}/api/wallet/me/withdrawals","host":["{{wallet_url}}"],"path":["api","wallet","me","withdrawals"]}}},
        {"name":"6.2 replay same key → 200 cached","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('200',()=>pm.response.to.have.status(200));","pm.test('same withdrawal id',()=>pm.expect(pm.response.json().id).to.eql(pm.environment.get('w_id')));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{user_jwt_alice}}"},{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"{{w_idem}}"}],"body":{"mode":"raw","raw":"{\"amountCents\":10000,\"destination\":{\"type\":\"bank\",\"iban\":\"EG800000000000000000000001\"}}"},"url":{"raw":"{{wallet_url}}/api/wallet/me/withdrawals","host":["{{wallet_url}}"],"path":["api","wallet","me","withdrawals"]}}},
        {"name":"6.3 below minimum (4999) → 422","event":[{"listen":"test","script":{"type":"text/javascript","exec":["// Default wallet.withdrawal.minimum-cents = 5000","pm.test('422',()=>pm.response.to.have.status(422));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{user_jwt_alice}}"},{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"k-w-min-{{$timestamp}}"}],"body":{"mode":"raw","raw":"{\"amountCents\":4999,\"destination\":{\"type\":\"bank\",\"iban\":\"EG800000000000000000000001\"}}"},"url":{"raw":"{{wallet_url}}/api/wallet/me/withdrawals","host":["{{wallet_url}}"],"path":["api","wallet","me","withdrawals"]}}},
        {"name":"6.4 negative amount → 400","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('400',()=>pm.response.to.have.status(400));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{user_jwt_alice}}"},{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"k-w-neg-{{$timestamp}}"}],"body":{"mode":"raw","raw":"{\"amountCents\":-100,\"destination\":{\"type\":\"bank\",\"iban\":\"EG800000000000000000000001\"}}"},"url":{"raw":"{{wallet_url}}/api/wallet/me/withdrawals","host":["{{wallet_url}}"],"path":["api","wallet","me","withdrawals"]}}},
        {"name":"6.5 missing destination → 400","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('400',()=>pm.response.to.have.status(400));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{user_jwt_alice}}"},{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"k-w-nodest-{{$timestamp}}"}],"body":{"mode":"raw","raw":"{\"amountCents\":5000}"},"url":{"raw":"{{wallet_url}}/api/wallet/me/withdrawals","host":["{{wallet_url}}"],"path":["api","wallet","me","withdrawals"]}}},
        {"name":"6.6 amount exceeds balance → 400 (Wallet PDF Decision 4.1)","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('400 InsufficientBalance',()=>pm.response.to.have.status(400));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{user_jwt_alice}}"},{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"k-w-over-{{$timestamp}}"}],"body":{"mode":"raw","raw":"{\"amountCents\":99999999,\"destination\":{\"type\":\"bank\",\"iban\":\"EG800000000000000000000001\"}}"},"url":{"raw":"{{wallet_url}}/api/wallet/me/withdrawals","host":["{{wallet_url}}"],"path":["api","wallet","me","withdrawals"]}}},
        {"name":"6.7 GET /withdrawals (alice's list) → 200 contains w_id","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('200',()=>pm.response.to.have.status(200));","const list=pm.response.json();","pm.test('w_id is in the list',()=>pm.expect(list.map(x=>x.id)).to.include(pm.environment.get('w_id')));"]}}],"request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{user_jwt_alice}}"}],"url":{"raw":"{{wallet_url}}/api/wallet/me/withdrawals","host":["{{wallet_url}}"],"path":["api","wallet","me","withdrawals"]}}},
        {"name":"6.8 cancel pending → 200 status changes","event":[{"listen":"test","script":{"type":"text/javascript","exec":["// Cancel may 200/4xx depending on whether Payment-side moved to SUBMITTING.","// In the dev stub it usually replies fast; we accept either Pending→CANCELLED","// or 409/422 if it already advanced.","pm.test('2xx or 4xx',()=>pm.expect(pm.response.code).to.be.below(500));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{user_jwt_alice}}"}],"url":{"raw":"{{wallet_url}}/api/wallet/me/withdrawals/{{w_id}}/cancel","host":["{{wallet_url}}"],"path":["api","wallet","me","withdrawals","{{w_id}}","cancel"]}}}
