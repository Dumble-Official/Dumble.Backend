        {"name":"1.4 USER JWT (wrong signing key) → 401","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('status 401',()=>pm.response.to.have.status(401));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{user_jwt}}"},{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"k-user-{{$timestamp}}"}],"body":{"mode":"raw","raw":"{\"userId\":\"00000099-0000-0000-0000-000000000001\",\"amountCents\":1000,\"currency\":\"EGP\",\"callerReference\":\"qa-{{$timestamp}}\"}"},"url":{"raw":"{{payment_url}}/api/payment/charges","host":["{{payment_url}}"],"path":["api","payment","charges"]}}},
