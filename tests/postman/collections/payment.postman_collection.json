        {"name":"1.10 POST /payment/payment-methods/tokenize no auth → 401","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('status 401',()=>pm.response.to.have.status(401));"]}}],"request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\"userId\":\"00000099-0000-0000-0000-000000000001\",\"token\":\"tok\",\"methodType\":\"CARD\"}"},"url":{"raw":"{{payment_url}}/api/payment/payment-methods/tokenize","host":["{{payment_url}}"],"path":["api","payment","payment-methods","tokenize"]}}}
      ]
