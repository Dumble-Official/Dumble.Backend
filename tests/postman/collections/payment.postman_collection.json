        {"name":"1.6 Expired system JWT → 401","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('status 401',()=>pm.response.to.have.status(401));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{system_jwt_expired}}"},{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"k-exp-{{$timestamp}}"}],"body":{"mode":"raw","raw":"{\"userId\":\"00000099-0000-0000-0000-000000000001\",\"amountCents\":1000,\"currency\":\"EGP\",\"callerReference\":\"qa-{{$timestamp}}\"}"},"url":{"raw":"{{payment_url}}/api/payment/charges","host":["{{payment_url}}"],"path":["api","payment","charges"]}}},
        {"name":"1.7 POST /payment/payouts no auth → 401","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('status 401',()=>pm.response.to.have.status(401));"]}}],"request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"k-p-{{$timestamp}}"}],"body":{"mode":"raw","raw":"{\"sellerId\":\"00000099-0000-0000-0000-000000000002\",\"amountCents\":10000,\"currency\":\"EGP\",\"destination\":{\"iban\":\"EG12345\"},\"callerReference\":\"qa-{{$timestamp}}\"}"},"url":{"raw":"{{payment_url}}/api/payment/payouts","host":["{{payment_url}}"],"path":["api","payment","payouts"]}}},
