    {
      "name": "2. Operational (public)",
      "item": [
        {"name":"2.1 GET /actuator/health (no auth) → 200","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('status 200',()=>pm.response.to.have.status(200));","pm.test('status is UP',()=>pm.expect(pm.response.json().status).to.eql('UP'));"]}}],"request":{"method":"GET","header":[],"url":{"raw":"{{payment_url}}/api/actuator/health","host":["{{payment_url}}"],"path":["api","actuator","health"]}}},
        {"name":"2.2 GET /actuator/info (no auth)","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('status 200 or 404 (exposure-dependent)',()=>pm.expect([200,404]).to.include(pm.response.code));"]}}],"request":{"method":"GET","header":[],"url":{"raw":"{{payment_url}}/api/actuator/info","host":["{{payment_url}}"],"path":["api","actuator","info"]}}}
