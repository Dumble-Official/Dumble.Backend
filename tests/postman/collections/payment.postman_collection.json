    {
      "name": "3. Charge — validation matrix",
      "item": [
        {"name":"3.1 No Idempotency-Key header → 400","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('status 400 (required header missing)',()=>pm.response.to.have.status(400));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{system_jwt_service}}"},{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\"userId\":\"00000099-0000-0000-0000-000000000001\",\"amountCents\":1000,\"currency\":\"EGP\",\"callerReference\":\"qa-{{$timestamp}}\"}"},"url":{"raw":"{{payment_url}}/api/payment/charges","host":["{{payment_url}}"],"path":["api","payment","charges"]}}},
        {"name":"3.2 Empty body → 400 (HttpMessageNotReadable)","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('status 400 (no 5xx)',()=>pm.response.to.have.status(400));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{system_jwt_service}}"},{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"k-empty-{{$timestamp}}"}],"url":{"raw":"{{payment_url}}/api/payment/charges","host":["{{payment_url}}"],"path":["api","payment","charges"]}}},
        {"name":"3.3 Missing userId → 400","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('status 400',()=>pm.response.to.have.status(400));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{system_jwt_service}}"},{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"k-nuid-{{$timestamp}}"}],"body":{"mode":"raw","raw":"{\"amountCents\":1000,\"currency\":\"EGP\",\"callerReference\":\"qa-{{$timestamp}}\"}"},"url":{"raw":"{{payment_url}}/api/payment/charges","host":["{{payment_url}}"],"path":["api","payment","charges"]}}},
        {"name":"3.4 Malformed userId UUID → 400","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('status 400',()=>pm.response.to.have.status(400));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{system_jwt_service}}"},{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"k-buid-{{$timestamp}}"}],"body":{"mode":"raw","raw":"{\"userId\":\"not-a-uuid\",\"amountCents\":1000,\"currency\":\"EGP\",\"callerReference\":\"qa-{{$timestamp}}\"}"},"url":{"raw":"{{payment_url}}/api/payment/charges","host":["{{payment_url}}"],"path":["api","payment","charges"]}}},
        {"name":"3.5 amountCents = 0 → 400 (@Positive)","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('status 400',()=>pm.response.to.have.status(400));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{system_jwt_service}}"},{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"k-zero-{{$timestamp}}"}],"body":{"mode":"raw","raw":"{\"userId\":\"00000099-0000-0000-0000-000000000001\",\"amountCents\":0,\"currency\":\"EGP\",\"callerReference\":\"qa-{{$timestamp}}\"}"},"url":{"raw":"{{payment_url}}/api/payment/charges","host":["{{payment_url}}"],"path":["api","payment","charges"]}}},
        {"name":"3.6 amountCents < 0 → 400 (@Positive)","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('status 400',()=>pm.response.to.have.status(400));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{system_jwt_service}}"},{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"k-neg-{{$timestamp}}"}],"body":{"mode":"raw","raw":"{\"userId\":\"00000099-0000-0000-0000-000000000001\",\"amountCents\":-100,\"currency\":\"EGP\",\"callerReference\":\"qa-{{$timestamp}}\"}"},"url":{"raw":"{{payment_url}}/api/payment/charges","host":["{{payment_url}}"],"path":["api","payment","charges"]}}},
        {"name":"3.7 amountCents as string → 400 (type-mismatch)","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('status 400',()=>pm.response.to.have.status(400));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{system_jwt_service}}"},{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"k-str-{{$timestamp}}"}],"body":{"mode":"raw","raw":"{\"userId\":\"00000099-0000-0000-0000-000000000001\",\"amountCents\":\"not-a-number\",\"currency\":\"EGP\",\"callerReference\":\"qa-{{$timestamp}}\"}"},"url":{"raw":"{{payment_url}}/api/payment/charges","host":["{{payment_url}}"],"path":["api","payment","charges"]}}},
        {"name":"3.8 Malformed JSON body → 400","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('status 400',()=>pm.response.to.have.status(400));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{system_jwt_service}}"},{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"k-mj-{{$timestamp}}"}],"body":{"mode":"raw","raw":"{ not really json"},"url":{"raw":"{{payment_url}}/api/payment/charges","host":["{{payment_url}}"],"path":["api","payment","charges"]}}}
      ]
