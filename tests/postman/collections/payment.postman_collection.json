    {
      "name": "4. Charge — state machine + happy path",
      "item": [
        {"name":"4.1 POST /charges happy path → 201 with status=PENDING (stub returns PENDING)","event":[{"listen":"prerequest","script":{"type":"text/javascript","exec":["pm.environment.set('charge_idem_key', 'k-c-happy-' + pm.environment.get('run_stamp'));","pm.environment.set('charge_caller_ref', 'cref-c-happy-' + pm.environment.get('run_stamp'));"]}},{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('status 201',()=>pm.response.to.have.status(201));","const j = pm.response.json();","pm.test('has chargeId (UUID)', ()=>pm.expect(j.chargeId).to.match(/^[0-9a-f-]{36}$/i));","pm.test('status is Pending (stub provider returns PENDING; ChargeResponse serializes as Pending)', ()=>pm.expect(j.status).to.eql('Pending'));","pm.test('providerRef populated (stub-charge-...)', ()=>pm.expect(j.providerRef).to.match(/^stub-charge-/));","pm.environment.set('created_charge_id', j.chargeId);"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{system_jwt_service}}"},{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"{{charge_idem_key}}"}],"body":{"mode":"raw","raw":"{\n  \"userId\": \"00000099-0000-0000-0000-000000000101\",\n  \"amountCents\": 1500,\n  \"currency\": \"EGP\",\n  \"description\": \"qa happy-path charge\",\n  \"callerReference\": \"{{charge_caller_ref}}\"\n}"},"url":{"raw":"{{payment_url}}/api/payment/charges","host":["{{payment_url}}"],"path":["api","payment","charges"]}}},
        {"name":"4.2 GET /charges/{id} → 200 with same fields","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('status 200',()=>pm.response.to.have.status(200));","const j = pm.response.json();","pm.test('same charge id',()=>pm.expect(j.chargeId).to.eql(pm.environment.get('created_charge_id')));","pm.test('status still Pending (no webhook yet)',()=>pm.expect(j.status).to.eql('Pending'));"]}}],"request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{system_jwt_service}}"}],"url":{"raw":"{{payment_url}}/api/payment/charges/{{created_charge_id}}","host":["{{payment_url}}"],"path":["api","payment","charges","{{created_charge_id}}"]}}},
        {"name":"4.3 GET /charges/{nonexistent} → 404","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('status 404',()=>pm.response.to.have.status(404));"]}}],"request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{system_jwt_service}}"}],"url":{"raw":"{{payment_url}}/api/payment/charges/00000000-0000-0000-0000-000000000000","host":["{{payment_url}}"],"path":["api","payment","charges","00000000-0000-0000-0000-000000000000"]}}},
        {"name":"4.4 GET /charges/{malformed-uuid} → 400 (path-var conversion)","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('status 400 (not 500)',()=>pm.response.to.have.status(400));"]}}],"request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{system_jwt_service}}"}],"url":{"raw":"{{payment_url}}/api/payment/charges/not-a-uuid","host":["{{payment_url}}"],"path":["api","payment","charges","not-a-uuid"]}}}
      ]
    },
    {
      "name": "5. Charge — idempotency contract",
      "item": [
        {"name":"5.1 Replay SAME Idempotency-Key + SAME body → 200 (cached replay)","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('status 200 (NOT 201 — cached replay)',()=>pm.response.to.have.status(200));","const j = pm.response.json();","pm.test('returns the SAME charge id as 4.1',()=>pm.expect(j.chargeId).to.eql(pm.environment.get('created_charge_id')));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{system_jwt_service}}"},{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"{{charge_idem_key}}"}],"body":{"mode":"raw","raw":"{\n  \"userId\": \"00000099-0000-0000-0000-000000000101\",\n  \"amountCents\": 1500,\n  \"currency\": \"EGP\",\n  \"description\": \"qa happy-path charge\",\n  \"callerReference\": \"{{charge_caller_ref}}\"\n}"},"url":{"raw":"{{payment_url}}/api/payment/charges","host":["{{payment_url}}"],"path":["api","payment","charges"]}}},
        {"name":"5.2 Replay SAME Idempotency-Key + DIFFERENT body → 409 (strict body-hash variant)","event":[{"listen":"test","script":{"type":"text/javascript","exec":["// V4 added a SHA-256 hash of the request body on each idempotency_keys row.","// A replay under the same key with a mismatched body must fail with 409","// instead of silently returning the cached response — closes the","// retry-with-corrected-amount-silently-no-ops foot-gun.","pm.test('status 409 (strict body-mismatch)',()=>pm.response.to.have.status(409));","pm.test('error mentions different payload',()=>pm.expect((pm.response.json().message||'').toLowerCase()).to.include('different request payload'));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{system_jwt_service}}"},{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"{{charge_idem_key}}"}],"body":{"mode":"raw","raw":"{\n  \"userId\": \"00000099-0000-0000-0000-000000000101\",\n  \"amountCents\": 9999,\n  \"currency\": \"EGP\",\n  \"description\": \"different amount\",\n  \"callerReference\": \"{{charge_caller_ref}}\"\n}"},"url":{"raw":"{{payment_url}}/api/payment/charges","host":["{{payment_url}}"],"path":["api","payment","charges"]}}},
        {"name":"5.3 Different Idempotency-Key + SAME body → 201 new charge","event":[{"listen":"prerequest","script":{"type":"text/javascript","exec":["pm.environment.set('charge_idem_key2', 'k-c-different-' + pm.environment.get('run_stamp'));"]}},{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('status 201 (new charge)',()=>pm.response.to.have.status(201));","const j = pm.response.json();","pm.test('different id from charge 4.1',()=>pm.expect(j.chargeId).to.not.eql(pm.environment.get('created_charge_id')));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{system_jwt_service}}"},{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"{{charge_idem_key2}}"}],"body":{"mode":"raw","raw":"{\n  \"userId\": \"00000099-0000-0000-0000-000000000101\",\n  \"amountCents\": 1500,\n  \"currency\": \"EGP\",\n  \"description\": \"qa happy-path charge\",\n  \"callerReference\": \"{{charge_caller_ref}}-alt\"\n}"},"url":{"raw":"{{payment_url}}/api/payment/charges","host":["{{payment_url}}"],"path":["api","payment","charges"]}}}
      ]
    },
    {
      "name": "6. Refund",
      "item": [
        {"name":"6.1 POST /refunds on a PENDING charge → 422 (business rule: only SUCCEEDED can be refunded)","event":[{"listen":"prerequest","script":{"type":"text/javascript","exec":["pm.environment.set('refund_idem_key', 'k-r-' + pm.environment.get('run_stamp'));"]}},{"listen":"test","script":{"type":"text/javascript","exec":["// Stub charge stays PENDING (no webhook to advance it). Refund correctly","// refuses to operate on a non-SUCCEEDED charge → 422 BusinessRuleViolation.","// True refund happy-path requires either real Paymob webhook flow or direct","// DB advance — deferred to the cross-flow integration suite.","pm.test('status 422 (refund-on-PENDING rejected by business rule)',()=>pm.response.to.have.status(422));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{system_jwt_service}}"},{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"{{refund_idem_key}}"}],"body":{"mode":"raw","raw":"{\n  \"chargeId\": \"{{created_charge_id}}\",\n  \"amountCents\": 500,\n  \"destination\": \"WALLET\",\n  \"reason\": \"qa refund\"\n}"},"url":{"raw":"{{payment_url}}/api/payment/refunds","host":["{{payment_url}}"],"path":["api","payment","refunds"]}}},
        {"name":"6.2 POST /refunds for nonexistent chargeId → 4xx (not 500)","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('status 4xx (404 or 422)',()=>pm.expect(pm.response.code).to.be.within(400,499));","pm.test('not 500',()=>pm.expect(pm.response.code).to.not.eql(500));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{system_jwt_service}}"},{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"k-r-noexist-{{$timestamp}}"}],"body":{"mode":"raw","raw":"{\n  \"chargeId\": \"00000000-0000-0000-0000-000000000000\",\n  \"amountCents\": 500,\n  \"destination\": \"WALLET\"\n}"},"url":{"raw":"{{payment_url}}/api/payment/refunds","host":["{{payment_url}}"],"path":["api","payment","refunds"]}}},
        {"name":"6.3 POST /refunds missing destination → 400 (@NotBlank)","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('status 400',()=>pm.response.to.have.status(400));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{system_jwt_service}}"},{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"k-r-nodest-{{$timestamp}}"}],"body":{"mode":"raw","raw":"{\"chargeId\":\"{{created_charge_id}}\",\"amountCents\":100}"},"url":{"raw":"{{payment_url}}/api/payment/refunds","host":["{{payment_url}}"],"path":["api","payment","refunds"]}}},
        {"name":"6.4 POST /refunds amountCents > charge amount → behaviour check","event":[{"listen":"test","script":{"type":"text/javascript","exec":["// Charge 4.1 was 1500. Refund 999999 — document whether service caps, rejects, or accepts.","pm.test('not 5xx (no silent crash on over-refund)',()=>pm.expect(pm.response.code).to.be.below(500));","// If it's 422/400 the rule is enforced. If 201, the over-refund went through (potential finding).","console.log('Over-refund response code:', pm.response.code, 'body:', pm.response.text().substring(0, 200));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{system_jwt_service}}"},{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"k-r-over-{{$timestamp}}"}],"body":{"mode":"raw","raw":"{\"chargeId\":\"{{created_charge_id}}\",\"amountCents\":999999,\"destination\":\"WALLET\",\"reason\":\"qa over-refund\"}"},"url":{"raw":"{{payment_url}}/api/payment/refunds","host":["{{payment_url}}"],"path":["api","payment","refunds"]}}},
        {"name":"6.5 POST /refunds replay same Idempotency-Key after a 422 — behaviour check","event":[{"listen":"test","script":{"type":"text/javascript","exec":["// 6.1 failed at 422 (business rule). The orchestrator's behaviour for a","// replay of a failed-at-422 record is: returns 409 (key reserved, but the","// state stored is the conflict, not the success cache). Documenting the","// observed behaviour rather than asserting a strict expectation.","pm.test('status is one of 200/409/422 (observed: 409)',()=>pm.expect([200,409,422]).to.include(pm.response.code));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{system_jwt_service}}"},{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"{{refund_idem_key}}"}],"body":{"mode":"raw","raw":"{\"chargeId\":\"{{created_charge_id}}\",\"amountCents\":500,\"destination\":\"WALLET\",\"reason\":\"qa refund\"}"},"url":{"raw":"{{payment_url}}/api/payment/refunds","host":["{{payment_url}}"],"path":["api","payment","refunds"]}}}
      ]
    },
    {
      "name": "7. Payout",
      "item": [
        {"name":"7.1 POST /payouts happy path → 201 PENDING (stub payout)","event":[{"listen":"prerequest","script":{"type":"text/javascript","exec":["pm.environment.set('payout_idem','k-p-'+pm.environment.get('run_stamp'));","pm.environment.set('payout_ref','pref-'+pm.environment.get('run_stamp'));"]}},{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('status 201',()=>pm.response.to.have.status(201));","const j = pm.response.json();","pm.test('status Pending (stub)',()=>pm.expect(j.status).to.eql('Pending'));","pm.test('providerRef stub-payout-...',()=>pm.expect(j.providerRef).to.match(/^stub-payout-/));","pm.environment.set('created_payout_caller_ref', '{{payout_ref}}');"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{system_jwt_service}}"},{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"{{payout_idem}}"}],"body":{"mode":"raw","raw":"{\n  \"sellerId\": \"00000099-0000-0000-0000-000000000201\",\n  \"amountCents\": 25000,\n  \"currency\": \"EGP\",\n  \"destination\": {\"iban\": \"EG12345678901234567890\", \"bankName\": \"Test Bank\"},\n  \"destinationType\": \"BANK_ACCOUNT\",\n  \"callerReference\": \"{{payout_ref}}\",\n  \"cohortKey\": \"qa-cohort-{{run_stamp}}\"\n}"},"url":{"raw":"{{payment_url}}/api/payment/payouts","host":["{{payment_url}}"],"path":["api","payment","payouts"]}}},
        {"name":"7.2 GET /payouts/by-caller-ref/{ref} → 200 with the payout","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('status 200',()=>pm.response.to.have.status(200));","pm.test('lookup returns withdrawalId (shared DTO with Withdrawal — see PayoutLookupResponse, callerReference NOT echoed)',()=>pm.expect(pm.response.json()).to.have.property('withdrawalId'));"]}}],"request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{system_jwt_service}}"}],"url":{"raw":"{{payment_url}}/api/payment/payouts/by-caller-ref/{{payout_ref}}","host":["{{payment_url}}"],"path":["api","payment","payouts","by-caller-ref","{{payout_ref}}"]}}},
        {"name":"7.3 GET /payouts/by-caller-ref/{nonexistent} → 404","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('status 404',()=>pm.response.to.have.status(404));"]}}],"request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{system_jwt_service}}"}],"url":{"raw":"{{payment_url}}/api/payment/payouts/by-caller-ref/never-existed-xyz","host":["{{payment_url}}"],"path":["api","payment","payouts","by-caller-ref","never-existed-xyz"]}}},
        {"name":"7.4 POST /payouts missing sellerId → 400","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('status 400',()=>pm.response.to.have.status(400));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{system_jwt_service}}"},{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"k-p-nosid-{{$timestamp}}"}],"body":{"mode":"raw","raw":"{\"amountCents\":1000,\"destination\":{},\"callerReference\":\"x\"}"},"url":{"raw":"{{payment_url}}/api/payment/payouts","host":["{{payment_url}}"],"path":["api","payment","payouts"]}}},
        {"name":"7.5 POST /payouts missing destination → 400","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('status 400',()=>pm.response.to.have.status(400));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{system_jwt_service}}"},{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"k-p-nodest-{{$timestamp}}"}],"body":{"mode":"raw","raw":"{\"sellerId\":\"00000099-0000-0000-0000-000000000201\",\"amountCents\":1000,\"callerReference\":\"x\"}"},"url":{"raw":"{{payment_url}}/api/payment/payouts","host":["{{payment_url}}"],"path":["api","payment","payouts"]}}},
        {"name":"7.6 POST /payouts replay same Idempotency-Key → 200","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('status 200 (idempotent replay)',()=>pm.response.to.have.status(200));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{system_jwt_service}}"},{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"{{payout_idem}}"}],"body":{"mode":"raw","raw":"{\n  \"sellerId\": \"00000099-0000-0000-0000-000000000201\",\n  \"amountCents\": 25000,\n  \"currency\": \"EGP\",\n  \"destination\": {\"iban\": \"EG12345678901234567890\", \"bankName\": \"Test Bank\"},\n  \"destinationType\": \"BANK_ACCOUNT\",\n  \"callerReference\": \"{{payout_ref}}\",\n  \"cohortKey\": \"qa-cohort-{{run_stamp}}\"\n}"},"url":{"raw":"{{payment_url}}/api/payment/payouts","host":["{{payment_url}}"],"path":["api","payment","payouts"]}}}
      ]
    },
    {
      "name": "8. Withdrawal",
      "item": [
        {"name":"8.1 POST /withdrawals happy path → 201","event":[{"listen":"prerequest","script":{"type":"text/javascript","exec":["pm.environment.set('with_idem','k-w-'+pm.environment.get('run_stamp'));","pm.environment.set('with_ref','wref-'+pm.environment.get('run_stamp'));"]}},{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('status 201',()=>pm.response.to.have.status(201));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{system_jwt_service}}"},{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"{{with_idem}}"}],"body":{"mode":"raw","raw":"{\n  \"userId\": \"00000099-0000-0000-0000-000000000301\",\n  \"amountCents\": 5000,\n  \"currency\": \"EGP\",\n  \"destination\": {\"iban\": \"EG99999999999999999999\"},\n  \"callerReference\": \"{{with_ref}}\"\n}"},"url":{"raw":"{{payment_url}}/api/payment/withdrawals","host":["{{payment_url}}"],"path":["api","payment","withdrawals"]}}},
        {"name":"8.2 GET /withdrawals/by-caller-ref/{ref} → 200","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('status 200',()=>pm.response.to.have.status(200));"]}}],"request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{system_jwt_service}}"}],"url":{"raw":"{{payment_url}}/api/payment/withdrawals/by-caller-ref/{{with_ref}}","host":["{{payment_url}}"],"path":["api","payment","withdrawals","by-caller-ref","{{with_ref}}"]}}},
        {"name":"8.3 GET /withdrawals/by-caller-ref/{nonexistent} → 404","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('status 404',()=>pm.response.to.have.status(404));"]}}],"request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{system_jwt_service}}"}],"url":{"raw":"{{payment_url}}/api/payment/withdrawals/by-caller-ref/never-existed","host":["{{payment_url}}"],"path":["api","payment","withdrawals","by-caller-ref","never-existed"]}}},
        {"name":"8.4 POST /withdrawals replay → 200","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('status 200 (cached)',()=>pm.response.to.have.status(200));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{system_jwt_service}}"},{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"{{with_idem}}"}],"body":{"mode":"raw","raw":"{\n  \"userId\": \"00000099-0000-0000-0000-000000000301\",\n  \"amountCents\": 5000,\n  \"currency\": \"EGP\",\n  \"destination\": {\"iban\": \"EG99999999999999999999\"},\n  \"callerReference\": \"{{with_ref}}\"\n}"},"url":{"raw":"{{payment_url}}/api/payment/withdrawals","host":["{{payment_url}}"],"path":["api","payment","withdrawals"]}}}
      ]
    },
    {
      "name": "9. Payment method tokenization",
      "item": [
        {"name":"9.1 POST /payment-methods/tokenize happy path → 200/201","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('status 2xx',()=>pm.expect(pm.response.code).to.be.within(200,201));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{system_jwt_service}}"},{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n  \"userId\": \"00000099-0000-0000-0000-000000000401\",\n  \"token\": \"qa-tok-{{$timestamp}}\",\n  \"methodType\": \"CARD\",\n  \"label\": \"qa card\",\n  \"cardBrand\": \"VISA\",\n  \"last4\": \"4242\"\n}"},"url":{"raw":"{{payment_url}}/api/payment/payment-methods/tokenize","host":["{{payment_url}}"],"path":["api","payment","payment-methods","tokenize"]}}},
        {"name":"9.2 Missing required fields → 400","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('status 400',()=>pm.response.to.have.status(400));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{system_jwt_service}}"},{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\"userId\":\"00000099-0000-0000-0000-000000000401\"}"},"url":{"raw":"{{payment_url}}/api/payment/payment-methods/tokenize","host":["{{payment_url}}"],"path":["api","payment","payment-methods","tokenize"]}}},
        {"name":"9.3 last4 with wrong length (5 chars) — behaviour check","event":[{"listen":"test","script":{"type":"text/javascript","exec":["// DTO doesn't strictly enforce 4-char last4; document what service does",  "pm.test('not 5xx',()=>pm.expect(pm.response.code).to.be.below(500));","console.log('last4 with 5 chars response:', pm.response.code);"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{system_jwt_service}}"},{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\"userId\":\"00000099-0000-0000-0000-000000000401\",\"token\":\"tok-{{$timestamp}}\",\"methodType\":\"CARD\",\"last4\":\"42424\"}"},"url":{"raw":"{{payment_url}}/api/payment/payment-methods/tokenize","host":["{{payment_url}}"],"path":["api","payment","payment-methods","tokenize"]}}}
      ]
    },
    {
      "name": "10. Webhook (Paymob)",
      "item": [
        {"name":"10.1 No signature header → 401 (verifier returns valid=false)","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('status 401',()=>pm.response.to.have.status(401));"]}}],"request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\"obj\":{\"id\":12345}}"},"url":{"raw":"{{payment_url}}/api/payment/webhooks/paymob","host":["{{payment_url}}"],"path":["api","payment","webhooks","paymob"]}}},
        {"name":"10.2 Bad signature → 401","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('status 401',()=>pm.response.to.have.status(401));"]}}],"request":{"method":"POST","header":[{"key":"X-Paymob-Signature","value":"deadbeef"},{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\"obj\":{\"id\":12345}}"},"url":{"raw":"{{payment_url}}/api/payment/webhooks/paymob","host":["{{payment_url}}"],"path":["api","payment","webhooks","paymob"]}}},
        {"name":"10.3 Empty body → 401 (verifier: empty_body)","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('status 4xx',()=>pm.expect(pm.response.code).to.be.within(400,499));"]}}],"request":{"method":"POST","header":[{"key":"X-Paymob-Signature","value":"dev-stub-ok"},{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":""},"url":{"raw":"{{payment_url}}/api/payment/webhooks/paymob","host":["{{payment_url}}"],"path":["api","payment","webhooks","paymob"]}}},
        {"name":"10.4 dev-stub-ok bypass + valid obj.id → 200","event":[{"listen":"prerequest","script":{"type":"text/javascript","exec":["// Paymob's obj.id is an integer; using a numeric value avoids any deserializer surprises.","pm.environment.set('webhook_event_id_num', (Date.now() % 9000000) + 1000000);"]}},{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('status 200',()=>pm.response.to.have.status(200));"]}}],"request":{"method":"POST","header":[{"key":"X-Paymob-Signature","value":"dev-stub-ok"},{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\"type\":\"TRANSACTION\",\"obj\":{\"id\":{{webhook_event_id_num}},\"amount_cents\":1500,\"currency\":\"EGP\",\"success\":true,\"order\":{\"id\":777},\"merchant_order_id\":\"qa-test\"}}"},"url":{"raw":"{{payment_url}}/api/payment/webhooks/paymob","host":["{{payment_url}}"],"path":["api","payment","webhooks","paymob"]}}},
        {"name":"10.5 Replay same event id → 200 (dedup, no second processing)","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('status 200 (dedup)',()=>pm.response.to.have.status(200));"]}}],"request":{"method":"POST","header":[{"key":"X-Paymob-Signature","value":"dev-stub-ok"},{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\"type\":\"TRANSACTION\",\"obj\":{\"id\":{{webhook_event_id_num}},\"amount_cents\":1500,\"currency\":\"EGP\",\"success\":true,\"order\":{\"id\":777},\"merchant_order_id\":\"qa-test\"}}"},"url":{"raw":"{{payment_url}}/api/payment/webhooks/paymob","host":["{{payment_url}}"],"path":["api","payment","webhooks","paymob"]}}},
        {"name":"10.6 Wrong Content-Type → 415","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('status 4xx (415 typical)',()=>pm.expect(pm.response.code).to.be.within(400,499));"]}}],"request":{"method":"POST","header":[{"key":"X-Paymob-Signature","value":"dev-stub-ok"},{"key":"Content-Type","value":"text/plain"}],"body":{"mode":"raw","raw":"plain text body"},"url":{"raw":"{{payment_url}}/api/payment/webhooks/paymob","host":["{{payment_url}}"],"path":["api","payment","webhooks","paymob"]}}},
        {"name":"10.7 Missing obj.id (dedup key) → 401 (verifier: missing event id)","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('status 401',()=>pm.response.to.have.status(401));"]}}],"request":{"method":"POST","header":[{"key":"X-Paymob-Signature","value":"dev-stub-ok"},{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\"obj\":{\"amount_cents\":100}}"},"url":{"raw":"{{payment_url}}/api/payment/webhooks/paymob","host":["{{payment_url}}"],"path":["api","payment","webhooks","paymob"]}}},
        {"name":"10.8 Malformed JSON → 401 or 400","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('status 4xx (not 5xx)',()=>pm.expect(pm.response.code).to.be.within(400,499));"]}}],"request":{"method":"POST","header":[{"key":"X-Paymob-Signature","value":"dev-stub-ok"},{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{not json"},"url":{"raw":"{{payment_url}}/api/payment/webhooks/paymob","host":["{{payment_url}}"],"path":["api","payment","webhooks","paymob"]}}},
        {"name":"10.9 Alternate header name `hmac` → 200 (controller supports it)","event":[{"listen":"prerequest","script":{"type":"text/javascript","exec":["pm.environment.set('webhook_event_id2_num', Date.now() % 9999999);"]}},{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('status 200 (alt header honored)',()=>pm.response.to.have.status(200));"]}}],"request":{"method":"POST","header":[{"key":"hmac","value":"dev-stub-ok"},{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\"type\":\"TRANSACTION\",\"obj\":{\"id\":{{webhook_event_id2_num}},\"success\":true}}"},"url":{"raw":"{{payment_url}}/api/payment/webhooks/paymob","host":["{{payment_url}}"],"path":["api","payment","webhooks","paymob"]}}}
      ]
    },
    {
      "name": "11. HTTP semantics",
      "item": [
        {"name":"11.1 GET on POST endpoint /payment/charges → 405","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('status 405 (or 401 if security blocks first)',()=>pm.expect([401,405]).to.include(pm.response.code));"]}}],"request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{system_jwt_service}}"}],"url":{"raw":"{{payment_url}}/api/payment/charges","host":["{{payment_url}}"],"path":["api","payment","charges"]}}},
        {"name":"11.2 DELETE on charges → 405 or 401","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('not 5xx',()=>pm.expect(pm.response.code).to.be.below(500));"]}}],"request":{"method":"DELETE","header":[{"key":"Authorization","value":"Bearer {{system_jwt_service}}"}],"url":{"raw":"{{payment_url}}/api/payment/charges/{{created_charge_id}}","host":["{{payment_url}}"],"path":["api","payment","charges","{{created_charge_id}}"]}}},
        {"name":"11.3 Wrong content-type on /charges → 415","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('status 415 or 400',()=>pm.expect([400,415]).to.include(pm.response.code));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{system_jwt_service}}"},{"key":"Content-Type","value":"text/plain"},{"key":"Idempotency-Key","value":"k-ct-{{$timestamp}}"}],"body":{"mode":"raw","raw":"this isn't json"},"url":{"raw":"{{payment_url}}/api/payment/charges","host":["{{payment_url}}"],"path":["api","payment","charges"]}}}
      ]
    },
    {
      "name": "12. Admin recon — suspected unreachable endpoint",
      "item": [
        {"name":"12.1 GET /admin/payment/recon no token → 401","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('status 401',()=>pm.response.to.have.status(401));"]}}],"request":{"method":"GET","header":[],"url":{"raw":"{{payment_url}}/api/admin/payment/recon","host":["{{payment_url}}"],"path":["api","admin","payment","recon"]}}},
        {"name":"12.2 With system JWT (iss=subscription-service) → 403 expected (no ROLE_ADMIN)","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('FINDING — 403 expected; if 200, ADMIN role somehow granted; if 500, exception-handler gap',()=>pm.expect([403]).to.include(pm.response.code));","if (pm.response.code !== 403) console.log('UNEXPECTED:', pm.response.code, pm.response.text().substring(0,200));"]}}],"request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{system_jwt_service}}"}],"url":{"raw":"{{payment_url}}/api/admin/payment/recon","host":["{{payment_url}}"],"path":["api","admin","payment","recon"]}}},
        {"name":"12.3 With system JWT (iss=admin) → 200 (ROLE_ADMIN granted by the filter for the admin issuer)","event":[{"listen":"test","script":{"type":"text/javascript","exec":["// SystemAuthenticationFilter grants ROLE_ADMIN when iss=admin (in addition to","// the per-issuer ROLE_SERVICE_<ISS>), so /admin/payment/recon is now reachable.","pm.test('status 200 (reconciliation endpoint reachable)',()=>pm.response.to.have.status(200));"]}}],"request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{system_jwt_admin}}"}],"url":{"raw":"{{payment_url}}/api/admin/payment/recon","host":["{{payment_url}}"],"path":["api","admin","payment","recon"]}}}
      ]
    },
    {
      "name": "13. Cross-flow journey",
      "item": [
        {"name":"13.1 New charge → 201 PENDING","event":[{"listen":"prerequest","script":{"type":"text/javascript","exec":["pm.environment.set('cf_idem','k-cf-c-'+pm.environment.get('run_stamp'));","pm.environment.set('cf_ref','cf-c-'+pm.environment.get('run_stamp'));"]}},{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('status 201',()=>pm.response.to.have.status(201));","pm.environment.set('cf_charge_id', pm.response.json().chargeId);"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{system_jwt_service}}"},{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"{{cf_idem}}"}],"body":{"mode":"raw","raw":"{\"userId\":\"00000099-0000-0000-0000-000000000501\",\"amountCents\":2000,\"currency\":\"EGP\",\"description\":\"cross-flow\",\"callerReference\":\"{{cf_ref}}\"}"},"url":{"raw":"{{payment_url}}/api/payment/charges","host":["{{payment_url}}"],"path":["api","payment","charges"]}}},
        {"name":"13.2 Refund on the just-created (PENDING) charge → 422 (business rule)","event":[{"listen":"prerequest","script":{"type":"text/javascript","exec":["pm.environment.set('cf_r_idem','k-cf-r-'+pm.environment.get('run_stamp'));"]}},{"listen":"test","script":{"type":"text/javascript","exec":["// Same as 6.1 — refund refuses non-SUCCEEDED charges. Documenting","// the design constraint as part of the cross-flow journey.","pm.test('status 422',()=>pm.response.to.have.status(422));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{system_jwt_service}}"},{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"{{cf_r_idem}}"}],"body":{"mode":"raw","raw":"{\"chargeId\":\"{{cf_charge_id}}\",\"amountCents\":500,\"destination\":\"WALLET\",\"reason\":\"cf refund\"}"},"url":{"raw":"{{payment_url}}/api/payment/refunds","host":["{{payment_url}}"],"path":["api","payment","refunds"]}}},
        {"name":"13.3 GET the charge → status still PENDING (refund doesn't reverse the charge row)","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('status 200',()=>pm.response.to.have.status(200));","const j = pm.response.json();","pm.test('charge status unchanged (still Pending — refund is separate row)',()=>pm.expect(j.status).to.eql('Pending'));"]}}],"request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{system_jwt_service}}"}],"url":{"raw":"{{payment_url}}/api/payment/charges/{{cf_charge_id}}","host":["{{payment_url}}"],"path":["api","payment","charges","{{cf_charge_id}}"]}}}
      ]
    },
    {
      "name": "14. Through-gateway (Payment isn't designed for user-side ingress)",
      "item": [
        {"name":"14.1 POST /api/payment/charges via gateway no token → 401 (gateway filter)","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('status 401',()=>pm.response.to.have.status(401));"]}}],"request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"k-g-no-{{$timestamp}}"}],"body":{"mode":"raw","raw":"{}"},"url":{"raw":"{{gateway_url}}/api/payment/charges","host":["{{gateway_url}}"],"path":["api","payment","charges"]}}},
        {"name":"14.2 POST /api/payment/charges via gateway with USER token → 4xx","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('status 4xx (gateway or payment rejects)',()=>pm.expect(pm.response.code).to.be.within(400,499));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{user_jwt}}"},{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"k-g-user-{{$timestamp}}"}],"body":{"mode":"raw","raw":"{\"userId\":\"00000099-0000-0000-0000-000000000601\",\"amountCents\":100,\"currency\":\"EGP\",\"callerReference\":\"gw-{{$timestamp}}\"}"},"url":{"raw":"{{gateway_url}}/api/payment/charges","host":["{{gateway_url}}"],"path":["api","payment","charges"]}}}
      ]
    }
  ]
}
