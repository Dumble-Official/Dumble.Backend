    {
      "name": "3. PRO upgrade idempotency contract",
      "item": [
        {"name":"3.1 POST /me/plan/upgrade no Idempotency-Key → 400","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('400',()=>pm.response.to.have.status(400));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{user_jwt_participant}}"},{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\"paymentMethodToken\":\"tok-test-{{$timestamp}}\",\"paymentMethodType\":\"CARD\"}"},"url":{"raw":"{{subscription_url}}/api/me/plan/upgrade","host":["{{subscription_url}}"],"path":["api","me","plan","upgrade"]}}},
        {"name":"3.2 POST /me/plan/upgrade invalid key chars → 400","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('400 invalid key',()=>pm.response.to.have.status(400));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{user_jwt_participant}}"},{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"key with spaces"}],"body":{"mode":"raw","raw":"{\"paymentMethodToken\":\"tok-{{$timestamp}}\",\"paymentMethodType\":\"CARD\"}"},"url":{"raw":"{{subscription_url}}/api/me/plan/upgrade","host":["{{subscription_url}}"],"path":["api","me","plan","upgrade"]}}},
        {"name":"3.3 POST /me/plan/upgrade 129-char key → 400","event":[{"listen":"prerequest","script":{"type":"text/javascript","exec":["pm.variables.set('long_key','a'.repeat(129));"]}},{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('400 length cap',()=>pm.response.to.have.status(400));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{user_jwt_participant}}"},{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"{{long_key}}"}],"body":{"mode":"raw","raw":"{\"paymentMethodToken\":\"tok-{{$timestamp}}\",\"paymentMethodType\":\"CARD\"}"},"url":{"raw":"{{subscription_url}}/api/me/plan/upgrade","host":["{{subscription_url}}"],"path":["api","me","plan","upgrade"]}}}
      ]
    },
    {
      "name": "4. Bundle subscriptions (negative paths)",
      "item": [
        {"name":"4.1 POST /checkout no Idempotency-Key → 400","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('400',()=>pm.response.to.have.status(400));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{user_jwt_participant}}"},{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\"bundleId\":\"00000000-0000-0000-0000-000000000001\"}"},"url":{"raw":"{{subscription_url}}/api/bundle-subscriptions/checkout","host":["{{subscription_url}}"],"path":["api","bundle-subscriptions","checkout"]}}},
        {"name":"4.2 POST /checkout malformed UUID → 400","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('400',()=>pm.response.to.have.status(400));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{user_jwt_participant}}"},{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"k-baduuid-{{$timestamp}}"}],"body":{"mode":"raw","raw":"{\"bundleId\":\"not-a-uuid\"}"},"url":{"raw":"{{subscription_url}}/api/bundle-subscriptions/checkout","host":["{{subscription_url}}"],"path":["api","bundle-subscriptions","checkout"]}}},
        {"name":"4.3 POST /checkout nonexistent bundle → 4xx (Bundle-down → 500 is a degradation FINDING)","event":[{"listen":"test","script":{"type":"text/javascript","exec":["// FINDING: when the Bundle service (.NET) is unreachable, Subscription","// returns a generic 500 instead of 502/503 with context. With Bundle UP","// the expected behavior is 404/422. We accept either here so this test","// doesn't false-negative depending on Bundle's availability — the","// degradation gap is tracked separately.","pm.test('4xx (Bundle up) or 5xx (Bundle down)',()=>pm.expect(pm.response.code).to.be.at.least(400));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{user_jwt_participant}}"},{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"k-ghost-{{$timestamp}}"}],"body":{"mode":"raw","raw":"{\"bundleId\":\"00000000-0000-0000-0000-000000000000\"}"},"url":{"raw":"{{subscription_url}}/api/bundle-subscriptions/checkout","host":["{{subscription_url}}"],"path":["api","bundle-subscriptions","checkout"]}}},
        {"name":"4.4 GET /me/bundle-subscriptions → 200 list","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('200',()=>pm.response.to.have.status(200));","pm.test('is array',()=>pm.expect(pm.response.json()).to.be.an('array'));"]}}],"request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{user_jwt_participant}}"}],"url":{"raw":"{{subscription_url}}/api/me/bundle-subscriptions","host":["{{subscription_url}}"],"path":["api","me","bundle-subscriptions"]}}},
        {"name":"4.5 GET /bundle-subscriptions/nonexistent → 404","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('404',()=>pm.response.to.have.status(404));"]}}],"request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{user_jwt_participant}}"}],"url":{"raw":"{{subscription_url}}/api/bundle-subscriptions/00000000-0000-0000-0000-000000000000","host":["{{subscription_url}}"],"path":["api","bundle-subscriptions","00000000-0000-0000-0000-000000000000"]}}}
      ]
