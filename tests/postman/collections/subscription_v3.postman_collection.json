    {
      "name": "7. HTTP semantics",
      "item": [
        {"name":"7.1 PUT /plans (authenticated) → 405","event":[{"listen":"test","script":{"type":"text/javascript","exec":["// Auth filter runs first; without a token we'd just get 401. To probe the","// method-not-allowed path we authenticate and then PUT.","pm.test('405',()=>pm.response.to.have.status(405));"]}}],"request":{"method":"PUT","header":[{"key":"Authorization","value":"Bearer {{user_jwt_participant}}"}],"url":{"raw":"{{subscription_url}}/api/plans","host":["{{subscription_url}}"],"path":["api","plans"]}}},
        {"name":"7.2 POST text/plain → 415","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('415',()=>pm.response.to.have.status(415));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{user_jwt_participant}}"},{"key":"Content-Type","value":"text/plain"},{"key":"Idempotency-Key","value":"k-415-{{$timestamp}}"}],"body":{"mode":"raw","raw":"plain text body"},"url":{"raw":"{{subscription_url}}/api/me/plan/upgrade","host":["{{subscription_url}}"],"path":["api","me","plan","upgrade"]}}},
        {"name":"7.3 malformed JSON → 400","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('400',()=>pm.response.to.have.status(400));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{user_jwt_participant}}"},{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"k-malformed-{{$timestamp}}"}],"body":{"mode":"raw","raw":"{not real json"},"url":{"raw":"{{subscription_url}}/api/me/plan/upgrade","host":["{{subscription_url}}"],"path":["api","me","plan","upgrade"]}}},
