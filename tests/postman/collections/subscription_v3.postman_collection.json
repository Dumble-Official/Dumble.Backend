{
  "info": {
    "_postman_id": "8a1b9b00-0001-4000-8000-00000000000a",
    "name": "Dumble Subscription — v3 QA Suite (level-up)",
    "description": "Full contract surface for Subscription, level-up edition. Dual-auth: most endpoints require a user JWT (signed with JWT_SECRET); /webhooks/system/** require a system JWT (aud=subscription, exp required — both enforced in this branch's SystemTokenVerifier fix); /plans is permitAll; /admin/** requires user JWT with ROLE_ADMIN. Hits Subscription direct on its host port (18182) for system-token cases so the gateway's user-JWT filter doesn't strip the bearer, plus through-gateway smoke tests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Auth boundary",
      "item": [
        {"name":"1.1 GET /plans no token → 401 (SecurityConfig requires auth on every non-actuator path)","event":[{"listen":"test","script":{"type":"text/javascript","exec":["// SecurityConfig.filterChain → .anyRequest().authenticated() so /plans","// requires a user JWT even though the catalog is the kind of data you'd","// usually expose publicly. The team chose 'no public-read carve-out' to","// match the gateway's allowlist and avoid cross-service mismatch.","pm.test('401',()=>pm.response.to.have.status(401));"]}}],"request":{"method":"GET","header":[],"url":{"raw":"{{subscription_url}}/api/plans","host":["{{subscription_url}}"],"path":["api","plans"]}}},
        {"name":"1.2 GET /me/plan no token → 401","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('401',()=>pm.response.to.have.status(401));"]}}],"request":{"method":"GET","header":[],"url":{"raw":"{{subscription_url}}/api/me/plan","host":["{{subscription_url}}"],"path":["api","me","plan"]}}},
        {"name":"1.3 GET /me/plan expired token → 401","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('401',()=>pm.response.to.have.status(401));"]}}],"request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{user_jwt_expired}}"}],"url":{"raw":"{{subscription_url}}/api/me/plan","host":["{{subscription_url}}"],"path":["api","me","plan"]}}},
        {"name":"1.4 GET /me/plan wrong-key → 401","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('401',()=>pm.response.to.have.status(401));"]}}],"request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{user_jwt_wrong_key}}"}],"url":{"raw":"{{subscription_url}}/api/me/plan","host":["{{subscription_url}}"],"path":["api","me","plan"]}}},
        {"name":"1.5 GET /admin as participant → 403","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('403',()=>pm.response.to.have.status(403));"]}}],"request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{user_jwt_participant}}"}],"url":{"raw":"{{subscription_url}}/api/admin/platform/subscriptions","host":["{{subscription_url}}"],"path":["api","admin","platform","subscriptions"]}}},
        {"name":"1.6 GET /admin as admin → 200","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('200',()=>pm.response.to.have.status(200));"]}}],"request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{user_jwt_admin}}"}],"url":{"raw":"{{subscription_url}}/api/admin/platform/subscriptions","host":["{{subscription_url}}"],"path":["api","admin","platform","subscriptions"]}}},
        {"name":"1.7 POST /webhooks/system no token → 401","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('401',()=>pm.response.to.have.status(401));"]}}],"request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"},{"key":"X-Webhook-Event-Id","value":"k-noauth-{{$timestamp}}"}],"body":{"mode":"raw","raw":"{\"sellerId\":\"{{seller_user_id}}\",\"reason\":\"qa\"}"},"url":{"raw":"{{subscription_url}}/api/webhooks/system/seller-frozen","host":["{{subscription_url}}"],"path":["api","webhooks","system","seller-frozen"]}}},
        {"name":"1.8 POST /webhooks/system user JWT → 401","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('401',()=>pm.response.to.have.status(401));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{user_jwt_admin}}"},{"key":"Content-Type","value":"application/json"},{"key":"X-Webhook-Event-Id","value":"k-uj-{{$timestamp}}"}],"body":{"mode":"raw","raw":"{\"sellerId\":\"{{seller_user_id}}\",\"reason\":\"qa\"}"},"url":{"raw":"{{subscription_url}}/api/webhooks/system/seller-frozen","host":["{{subscription_url}}"],"path":["api","webhooks","system","seller-frozen"]}}},
        {"name":"1.9 POST /webhooks/system aud=payment → 401 (defense-in-depth)","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('401',()=>pm.response.to.have.status(401));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{system_jwt_payment_aud}}"},{"key":"Content-Type","value":"application/json"},{"key":"X-Webhook-Event-Id","value":"k-aud-{{$timestamp}}"}],"body":{"mode":"raw","raw":"{\"sellerId\":\"{{seller_user_id}}\",\"reason\":\"qa\"}"},"url":{"raw":"{{subscription_url}}/api/webhooks/system/seller-frozen","host":["{{subscription_url}}"],"path":["api","webhooks","system","seller-frozen"]}}},
        {"name":"1.10 POST /webhooks/system no aud → 401","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('401',()=>pm.response.to.have.status(401));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{system_jwt_no_aud}}"},{"key":"Content-Type","value":"application/json"},{"key":"X-Webhook-Event-Id","value":"k-noa-{{$timestamp}}"}],"body":{"mode":"raw","raw":"{\"sellerId\":\"{{seller_user_id}}\",\"reason\":\"qa\"}"},"url":{"raw":"{{subscription_url}}/api/webhooks/system/seller-frozen","host":["{{subscription_url}}"],"path":["api","webhooks","system","seller-frozen"]}}},
        {"name":"1.11 POST /webhooks/system wrong-key → 401","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('401',()=>pm.response.to.have.status(401));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{system_jwt_wrong_key}}"},{"key":"Content-Type","value":"application/json"},{"key":"X-Webhook-Event-Id","value":"k-wk-{{$timestamp}}"}],"body":{"mode":"raw","raw":"{\"sellerId\":\"{{seller_user_id}}\",\"reason\":\"qa\"}"},"url":{"raw":"{{subscription_url}}/api/webhooks/system/seller-frozen","host":["{{subscription_url}}"],"path":["api","webhooks","system","seller-frozen"]}}},
        {"name":"1.12 POST /webhooks/system expired → 401","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('401',()=>pm.response.to.have.status(401));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{system_jwt_expired}}"},{"key":"Content-Type","value":"application/json"},{"key":"X-Webhook-Event-Id","value":"k-ex-{{$timestamp}}"}],"body":{"mode":"raw","raw":"{\"sellerId\":\"{{seller_user_id}}\",\"reason\":\"qa\"}"},"url":{"raw":"{{subscription_url}}/api/webhooks/system/seller-frozen","host":["{{subscription_url}}"],"path":["api","webhooks","system","seller-frozen"]}}},
        {"name":"1.13 POST /webhooks/system no-exp → 401 (this branch enforces exp)","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('401 token without exp refused',()=>pm.response.to.have.status(401));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{system_jwt_no_exp}}"},{"key":"Content-Type","value":"application/json"},{"key":"X-Webhook-Event-Id","value":"k-ne-{{$timestamp}}"}],"body":{"mode":"raw","raw":"{\"sellerId\":\"{{seller_user_id}}\",\"reason\":\"qa\"}"},"url":{"raw":"{{subscription_url}}/api/webhooks/system/seller-frozen","host":["{{subscription_url}}"],"path":["api","webhooks","system","seller-frozen"]}}},
        {"name":"1.14 POST /webhooks/system signed system JWT (aud=subscription) → 200","event":[{"listen":"test","script":{"type":"text/javascript","exec":["// Forward-compat: Auth service is supposed to call this when banning a","// seller; the endpoint is currently unwired but the verify path must","// accept a properly-formed system token.","pm.test('2xx (signed system JWT accepted)',()=>pm.expect(pm.response.code).to.be.below(300));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{system_jwt_service}}"},{"key":"Content-Type","value":"application/json"},{"key":"X-Webhook-Event-Id","value":"k-ok-{{$timestamp}}"}],"body":{"mode":"raw","raw":"{\"sellerId\":\"{{seller_user_id}}\",\"reason\":\"qa-ban\"}"},"url":{"raw":"{{subscription_url}}/api/webhooks/system/seller-frozen","host":["{{subscription_url}}"],"path":["api","webhooks","system","seller-frozen"]}}}
      ]
    },
    {
      "name": "2. Plan catalog + me/plan",
      "item": [
        {"name":"2.1 GET /plans (authenticated) returns FREE + PRO","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('200',()=>pm.response.to.have.status(200));","const codes = pm.response.json().map(p=>p.code);","pm.test('has FREE',()=>pm.expect(codes).to.include('FREE'));","pm.test('has PRO',()=>pm.expect(codes).to.include('PRO'));"]}}],"request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{user_jwt_participant}}"}],"url":{"raw":"{{subscription_url}}/api/plans","host":["{{subscription_url}}"],"path":["api","plans"]}}},
        {"name":"2.2 GET /me/plan as participant → 200","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('200',()=>pm.response.to.have.status(200));","const j = pm.response.json();","pm.test('planCode in {FREE,PRO}',()=>pm.expect(['FREE','PRO']).to.include(j.planCode));"]}}],"request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{user_jwt_participant}}"}],"url":{"raw":"{{subscription_url}}/api/me/plan","host":["{{subscription_url}}"],"path":["api","me","plan"]}}},
        {"name":"2.3 GET /me/entitlements → 200, shape valid","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('200',()=>pm.response.to.have.status(200));","const j = pm.response.json();","pm.test('canUseChatbot is boolean',()=>pm.expect(j.canUseChatbot).to.be.a('boolean'));","pm.test('canDmAnyone is boolean',()=>pm.expect(j.canDmAnyone).to.be.a('boolean'));"]}}],"request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{user_jwt_participant}}"}],"url":{"raw":"{{subscription_url}}/api/me/entitlements","host":["{{subscription_url}}"],"path":["api","me","entitlements"]}}}
      ]
