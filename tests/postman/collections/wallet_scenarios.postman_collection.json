{
  "info": {
    "_postman_id": "8a1b9b00-0002-4000-8000-000000000008",
    "name": "Dumble Wallet — Real-World Scenarios",
    "description": "End-to-end flows that exercise the actual money paths. Credit + debit balance arithmetic (deterministic), withdrawal lifecycle (status progression), refund-on-cancel, idempotency body-hash strict variant (Decision 3.2), admin adjustment auditability, multi-user isolation. Hits Wallet direct on 18184 with mixed user/system JWTs. The webhook-driven completion path is covered by tests/postman/wallet_lifecycle.js — that one publishes the payment.withdrawal.completed event directly to dumble.events so we don't need Payment to ack.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "A. Credit + debit balance arithmetic",
      "item": [
        {"name":"A.1 setup: credit alice 10000","event":[{"listen":"prerequest","script":{"type":"text/javascript","exec":["const stamp = String(Date.now());","pm.environment.set('scn_a_stamp', stamp);","pm.environment.set('scn_a_idem1', 'k-scn-a1-' + stamp);"]}},{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('201',()=>pm.response.to.have.status(201));","const j=pm.response.json();","pm.environment.set('scn_a_bal_after_a1', j.newBalanceCents);","pm.test('balance >= 10000',()=>pm.expect(j.newBalanceCents).to.be.at.least(10000));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{system_jwt_service}}"},{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"{{scn_a_idem1}}"}],"body":{"mode":"raw","raw":"{\"userId\":\"{{alice_user_id}}\",\"amountCents\":10000,\"source\":\"BAN_REFUND\",\"externalRef\":\"scn-a1-{{scn_a_stamp}}\"}"},"url":{"raw":"{{wallet_url}}/api/wallet/credit","host":["{{wallet_url}}"],"path":["api","wallet","credit"]}}},
        {"name":"A.2 credit alice 3000 more (different source) → balance += 3000","event":[{"listen":"prerequest","script":{"type":"text/javascript","exec":["pm.environment.set('scn_a_idem2', 'k-scn-a2-' + pm.environment.get('scn_a_stamp'));"]}},{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('201',()=>pm.response.to.have.status(201));","const prev = parseInt(pm.environment.get('scn_a_bal_after_a1'));","pm.test('balance = prev + 3000',()=>pm.expect(pm.response.json().newBalanceCents).to.eql(prev + 3000));","pm.environment.set('scn_a_bal_after_a2', pm.response.json().newBalanceCents);"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{system_jwt_service}}"},{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"{{scn_a_idem2}}"}],"body":{"mode":"raw","raw":"{\"userId\":\"{{alice_user_id}}\",\"amountCents\":3000,\"source\":\"CHARGEBACK\",\"externalRef\":\"scn-a2-{{scn_a_stamp}}\"}"},"url":{"raw":"{{wallet_url}}/api/wallet/credit","host":["{{wallet_url}}"],"path":["api","wallet","credit"]}}},
        {"name":"A.3 debit alice 4500 → balance -= 4500","event":[{"listen":"prerequest","script":{"type":"text/javascript","exec":["pm.environment.set('scn_a_idem3', 'k-scn-a3-' + pm.environment.get('scn_a_stamp'));"]}},{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('201',()=>pm.response.to.have.status(201));","const prev = parseInt(pm.environment.get('scn_a_bal_after_a2'));","pm.test('balance = prev - 4500',()=>pm.expect(pm.response.json().newBalanceCents).to.eql(prev - 4500));","pm.environment.set('scn_a_bal_after_a3', pm.response.json().newBalanceCents);"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{user_jwt_alice}}"},{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"{{scn_a_idem3}}"}],"body":{"mode":"raw","raw":"{\"userId\":\"{{alice_user_id}}\",\"amountCents\":4500,\"source\":\"IN_APP_SPEND\",\"externalRef\":\"scn-a3-{{scn_a_stamp}}\"}"},"url":{"raw":"{{wallet_url}}/api/wallet/debit","host":["{{wallet_url}}"],"path":["api","wallet","debit"]}}},
        {"name":"A.4 GET /me/summary matches A.3 result","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('200',()=>pm.response.to.have.status(200));","const expected = parseInt(pm.environment.get('scn_a_bal_after_a3'));","pm.test('availableCents matches running total',()=>pm.expect(pm.response.json().availableCents).to.eql(expected));"]}}],"request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{user_jwt_alice}}"}],"url":{"raw":"{{wallet_url}}/api/wallet/me/summary","host":["{{wallet_url}}"],"path":["api","wallet","me","summary"]}}},
        {"name":"A.5 ledger entries reflect 3 ops (cumulative)","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('200',()=>pm.response.to.have.status(200));","const entries = pm.response.json().content;","const stamp = pm.environment.get('scn_a_stamp');","const ours = entries.filter(e => (e.externalRef||'').includes(stamp));","pm.test('at least 3 entries for this run',()=>pm.expect(ours.length).to.be.at.least(3));","pm.test('one IN_APP_SPEND debit',()=>pm.expect(ours.filter(e=>e.type==='DEBIT').length).to.be.at.least(1));","pm.test('two non-debit credits',()=>pm.expect(ours.filter(e=>e.type==='CREDIT').length).to.be.at.least(2));"]}}],"request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{user_jwt_alice}}"}],"url":{"raw":"{{wallet_url}}/api/wallet/me/entries?size=100","host":["{{wallet_url}}"],"path":["api","wallet","me","entries"],"query":[{"key":"size","value":"100"}]}}}
      ]
    },
    {
      "name": "B. Idempotency body-hash strict variant (Decision 3.2 strict)",
      "item": [
        {"name":"B.1 first credit → 201","event":[{"listen":"prerequest","script":{"type":"text/javascript","exec":["const stamp = String(Date.now());","pm.environment.set('scn_b_stamp', stamp);","pm.environment.set('scn_b_idem', 'k-scn-b-' + stamp);"]}},{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('201',()=>pm.response.to.have.status(201));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{system_jwt_service}}"},{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"{{scn_b_idem}}"}],"body":{"mode":"raw","raw":"{\"userId\":\"{{alice_user_id}}\",\"amountCents\":1000,\"source\":\"BAN_REFUND\",\"externalRef\":\"scn-b-{{scn_b_stamp}}\",\"memo\":\"original body\"}"},"url":{"raw":"{{wallet_url}}/api/wallet/credit","host":["{{wallet_url}}"],"path":["api","wallet","credit"]}}},
        {"name":"B.2 replay SAME key + SAME body → 200 cached","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('200 cached',()=>pm.response.to.have.status(200));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{system_jwt_service}}"},{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"{{scn_b_idem}}"}],"body":{"mode":"raw","raw":"{\"userId\":\"{{alice_user_id}}\",\"amountCents\":1000,\"source\":\"BAN_REFUND\",\"externalRef\":\"scn-b-{{scn_b_stamp}}\",\"memo\":\"original body\"}"},"url":{"raw":"{{wallet_url}}/api/wallet/credit","host":["{{wallet_url}}"],"path":["api","wallet","credit"]}}},
        {"name":"B.3 replay SAME key + DIFFERENT amount → 409 strict-body-mismatch","event":[{"listen":"test","script":{"type":"text/javascript","exec":["// V3 migration added request_hash. A replay under the same key with a","// mismatched body now fails 409 'different request payload' instead of","// silently returning the cached response (V3 strict variant of Decision 3.2).","pm.test('409',()=>pm.response.to.have.status(409));","pm.test('error mentions different payload',()=>pm.expect((pm.response.json().message||'').toLowerCase()).to.include('different request payload'));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{system_jwt_service}}"},{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"{{scn_b_idem}}"}],"body":{"mode":"raw","raw":"{\"userId\":\"{{alice_user_id}}\",\"amountCents\":99999,\"source\":\"BAN_REFUND\",\"externalRef\":\"scn-b-{{scn_b_stamp}}\",\"memo\":\"original body\"}"},"url":{"raw":"{{wallet_url}}/api/wallet/credit","host":["{{wallet_url}}"],"path":["api","wallet","credit"]}}},
        {"name":"B.4 replay SAME key + DIFFERENT memo → 409","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('409',()=>pm.response.to.have.status(409));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{system_jwt_service}}"},{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"{{scn_b_idem}}"}],"body":{"mode":"raw","raw":"{\"userId\":\"{{alice_user_id}}\",\"amountCents\":1000,\"source\":\"BAN_REFUND\",\"externalRef\":\"scn-b-{{scn_b_stamp}}\",\"memo\":\"MUTATED\"}"},"url":{"raw":"{{wallet_url}}/api/wallet/credit","host":["{{wallet_url}}"],"path":["api","wallet","credit"]}}},
        {"name":"B.5 SAME key + SAME body (different field order) → 200 cached (sorted-keys hash)","event":[{"listen":"test","script":{"type":"text/javascript","exec":["// hashMapper uses ORDER_MAP_ENTRIES_BY_KEYS, so semantically-equal JSON","// with different field order produces the same hash.","pm.test('200 cached (order-insensitive hash)',()=>pm.response.to.have.status(200));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{system_jwt_service}}"},{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"{{scn_b_idem}}"}],"body":{"mode":"raw","raw":"{\"memo\":\"original body\",\"externalRef\":\"scn-b-{{scn_b_stamp}}\",\"amountCents\":1000,\"source\":\"BAN_REFUND\",\"userId\":\"{{alice_user_id}}\"}"},"url":{"raw":"{{wallet_url}}/api/wallet/credit","host":["{{wallet_url}}"],"path":["api","wallet","credit"]}}}
      ]
    },
    {
      "name": "C. Withdrawal request lifecycle (HTTP-side)",
      "item": [
        {"name":"C.0 setup: top up alice 30000","event":[{"listen":"prerequest","script":{"type":"text/javascript","exec":["const stamp = String(Date.now());","pm.environment.set('scn_c_stamp', stamp);","pm.environment.set('scn_c_topup_idem', 'k-scn-c-topup-' + stamp);"]}},{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('topup 201',()=>pm.response.to.have.status(201));","pm.environment.set('scn_c_balance_after_topup', pm.response.json().newBalanceCents);"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{system_jwt_service}}"},{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"{{scn_c_topup_idem}}"}],"body":{"mode":"raw","raw":"{\"userId\":\"{{alice_user_id}}\",\"amountCents\":30000,\"source\":\"BAN_REFUND\",\"externalRef\":\"scn-c-topup-{{scn_c_stamp}}\"}"},"url":{"raw":"{{wallet_url}}/api/wallet/credit","host":["{{wallet_url}}"],"path":["api","wallet","credit"]}}},
        {"name":"C.1 withdraw 12000 → 201, available balance dropped by 12000","event":[{"listen":"prerequest","script":{"type":"text/javascript","exec":["pm.environment.set('scn_c_w_idem', 'k-scn-c-w-' + pm.environment.get('scn_c_stamp'));"]}},{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('201',()=>pm.response.to.have.status(201));","const j = pm.response.json();","pm.environment.set('scn_c_w_id', j.id);","pm.test('id is UUID-shaped',()=>pm.expect(j.id).to.match(/^[0-9a-f-]{36}$/));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{user_jwt_alice}}"},{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"{{scn_c_w_idem}}"}],"body":{"mode":"raw","raw":"{\"amountCents\":12000,\"destination\":{\"type\":\"bank\",\"iban\":\"EG800000000000000000000099\"}}"},"url":{"raw":"{{wallet_url}}/api/wallet/me/withdrawals","host":["{{wallet_url}}"],"path":["api","wallet","me","withdrawals"]}}},
        {"name":"C.2 summary: available balance dropped by 12000","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('200',()=>pm.response.to.have.status(200));","const j = pm.response.json();","const balBefore = parseInt(pm.environment.get('scn_c_balance_after_topup'));","pm.test('available dropped by exactly 12000',()=>pm.expect(j.availableCents).to.eql(balBefore - 12000));","pm.environment.set('scn_c_balance_after_withdraw', j.availableCents);"]}}],"request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{user_jwt_alice}}"}],"url":{"raw":"{{wallet_url}}/api/wallet/me/summary","host":["{{wallet_url}}"],"path":["api","wallet","me","summary"]}}},
        {"name":"C.3 cancel SENT withdrawal → 200 OR 4xx (depending on lifecycle position)","event":[{"listen":"test","script":{"type":"text/javascript","exec":["// Whether cancel is allowed depends on whether the row is still PENDING/","// SUBMITTING or has already advanced to SENT. Dev stub returns Pending so","// in this stack the cancel should succeed.","pm.test('not 5xx',()=>pm.expect(pm.response.code).to.be.below(500));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{user_jwt_alice}}"}],"url":{"raw":"{{wallet_url}}/api/wallet/me/withdrawals/{{scn_c_w_id}}/cancel","host":["{{wallet_url}}"],"path":["api","wallet","me","withdrawals","{{scn_c_w_id}}","cancel"]}}}
      ]
    },
    {
      "name": "D. Multi-user isolation (bob's wallet ≠ alice's wallet)",
      "item": [
        {"name":"D.1 credit bob 5000","event":[{"listen":"prerequest","script":{"type":"text/javascript","exec":["const stamp = String(Date.now());","pm.environment.set('scn_d_stamp', stamp);","pm.environment.set('scn_d_idem', 'k-scn-d-' + stamp);"]}},{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('201',()=>pm.response.to.have.status(201));","pm.environment.set('scn_d_bob_bal', pm.response.json().newBalanceCents);"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{system_jwt_service}}"},{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"{{scn_d_idem}}"}],"body":{"mode":"raw","raw":"{\"userId\":\"{{bob_user_id}}\",\"amountCents\":5000,\"source\":\"CHARGEBACK\",\"externalRef\":\"scn-d-{{scn_d_stamp}}\"}"},"url":{"raw":"{{wallet_url}}/api/wallet/credit","host":["{{wallet_url}}"],"path":["api","wallet","credit"]}}},
        {"name":"D.2 alice's balance unaffected","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('200',()=>pm.response.to.have.status(200));","const aliceBal = pm.response.json().availableCents;","const bobBal = parseInt(pm.environment.get('scn_d_bob_bal'));","pm.test('alice balance != bob balance (isolated)',()=>pm.expect(aliceBal).to.not.eql(bobBal));"]}}],"request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{user_jwt_alice}}"}],"url":{"raw":"{{wallet_url}}/api/wallet/me/summary","host":["{{wallet_url}}"],"path":["api","wallet","me","summary"]}}},
        {"name":"D.3 alice cannot debit bob's wallet → 403","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('403',()=>pm.response.to.have.status(403));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{user_jwt_alice}}"},{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"k-scn-d-evil-{{$timestamp}}"}],"body":{"mode":"raw","raw":"{\"userId\":\"{{bob_user_id}}\",\"amountCents\":100,\"source\":\"IN_APP_SPEND\"}"},"url":{"raw":"{{wallet_url}}/api/wallet/debit","host":["{{wallet_url}}"],"path":["api","wallet","debit"]}}},
        {"name":"D.4 bob's balance unchanged after alice's attempt","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('200',()=>pm.response.to.have.status(200));","const before = parseInt(pm.environment.get('scn_d_bob_bal'));","pm.test('bob balance unchanged',()=>pm.expect(pm.response.json().availableCents).to.eql(before));"]}}],"request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{system_jwt_service}}"}],"url":{"raw":"{{wallet_url}}/api/wallet/{{bob_user_id}}/summary","host":["{{wallet_url}}"],"path":["api","wallet","{{bob_user_id}}","summary"]}}}
      ]
    },
    {
      "name": "E. Admin adjustment is auditable",
      "item": [
        {"name":"E.1 admin CREDIT 1234 → 201","event":[{"listen":"prerequest","script":{"type":"text/javascript","exec":["const stamp = String(Date.now());","pm.environment.set('scn_e_stamp', stamp);","pm.environment.set('scn_e_idem', 'k-scn-e-' + stamp);"]}},{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('201',()=>pm.response.to.have.status(201));","pm.environment.set('scn_e_bal_after', pm.response.json().newBalanceCents);"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{user_jwt_admin}}"},{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"{{scn_e_idem}}"}],"body":{"mode":"raw","raw":"{\"amountCents\":1234,\"direction\":\"CREDIT\",\"memo\":\"audit probe scn-e-{{scn_e_stamp}}\"}"},"url":{"raw":"{{wallet_url}}/api/admin/wallet/{{alice_user_id}}/adjust","host":["{{wallet_url}}"],"path":["api","admin","wallet","{{alice_user_id}}","adjust"]}}},
        {"name":"E.2 admin DEBIT 234 → balance drops","event":[{"listen":"prerequest","script":{"type":"text/javascript","exec":["pm.environment.set('scn_e_idem2', 'k-scn-e2-' + pm.environment.get('scn_e_stamp'));"]}},{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('201',()=>pm.response.to.have.status(201));","const before = parseInt(pm.environment.get('scn_e_bal_after'));","pm.test('balance dropped by 234',()=>pm.expect(pm.response.json().newBalanceCents).to.eql(before - 234));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{user_jwt_admin}}"},{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"{{scn_e_idem2}}"}],"body":{"mode":"raw","raw":"{\"amountCents\":234,\"direction\":\"DEBIT\",\"memo\":\"reversal probe scn-e-{{scn_e_stamp}}\"}"},"url":{"raw":"{{wallet_url}}/api/admin/wallet/{{alice_user_id}}/adjust","host":["{{wallet_url}}"],"path":["api","admin","wallet","{{alice_user_id}}","adjust"]}}},
        {"name":"E.3 entries include the admin-memo string","event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('200',()=>pm.response.to.have.status(200));","const entries = pm.response.json().content;","const stamp = pm.environment.get('scn_e_stamp');","const auditEntries = entries.filter(e => (e.memo||'').includes(stamp));","pm.test('admin credit + debit memos both present',()=>pm.expect(auditEntries.length).to.be.at.least(2));","pm.test('one ADMIN_ADJUSTMENT credit',()=>pm.expect(auditEntries.filter(e=>e.type==='CREDIT'&&e.source==='ADMIN_ADJUSTMENT').length).to.be.at.least(1));","pm.test('one ADMIN_ADJUSTMENT debit',()=>pm.expect(auditEntries.filter(e=>e.type==='DEBIT'&&e.source==='ADMIN_ADJUSTMENT').length).to.be.at.least(1));"]}}],"request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{user_jwt_alice}}"}],"url":{"raw":"{{wallet_url}}/api/wallet/me/entries?size=200","host":["{{wallet_url}}"],"path":["api","wallet","me","entries"],"query":[{"key":"size","value":"200"}]}}}
      ]
    },
    {
      "name": "F. Source mapping (parseSource accepts SNAKE_CASE, PascalCase, all-caps)",
      "item": [
        {"name":"F.1 source 'CHARGEBACK' (all-caps, no underscore) → 201 (regression test for parseSource bug)","event":[{"listen":"prerequest","script":{"type":"text/javascript","exec":["pm.environment.set('scn_f_idem1', 'k-scn-f1-' + Date.now());"]}},{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('201',()=>pm.response.to.have.status(201));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{system_jwt_service}}"},{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"{{scn_f_idem1}}"}],"body":{"mode":"raw","raw":"{\"userId\":\"{{alice_user_id}}\",\"amountCents\":100,\"source\":\"CHARGEBACK\",\"externalRef\":\"f1\"}"},"url":{"raw":"{{wallet_url}}/api/wallet/credit","host":["{{wallet_url}}"],"path":["api","wallet","credit"]}}},
        {"name":"F.2 source 'Chargeback' (PascalCase) → 201","event":[{"listen":"prerequest","script":{"type":"text/javascript","exec":["pm.environment.set('scn_f_idem2', 'k-scn-f2-' + Date.now());"]}},{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('201',()=>pm.response.to.have.status(201));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{system_jwt_service}}"},{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"{{scn_f_idem2}}"}],"body":{"mode":"raw","raw":"{\"userId\":\"{{alice_user_id}}\",\"amountCents\":100,\"source\":\"Chargeback\",\"externalRef\":\"f2\"}"},"url":{"raw":"{{wallet_url}}/api/wallet/credit","host":["{{wallet_url}}"],"path":["api","wallet","credit"]}}},
        {"name":"F.3 source 'BAN_REFUND' (snake-case) → 201","event":[{"listen":"prerequest","script":{"type":"text/javascript","exec":["pm.environment.set('scn_f_idem3', 'k-scn-f3-' + Date.now());"]}},{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('201',()=>pm.response.to.have.status(201));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{system_jwt_service}}"},{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"{{scn_f_idem3}}"}],"body":{"mode":"raw","raw":"{\"userId\":\"{{alice_user_id}}\",\"amountCents\":100,\"source\":\"BAN_REFUND\",\"externalRef\":\"f3\"}"},"url":{"raw":"{{wallet_url}}/api/wallet/credit","host":["{{wallet_url}}"],"path":["api","wallet","credit"]}}},
        {"name":"F.4 IN_APP_SPEND on credit endpoint → 422 (wrong-flow source)","event":[{"listen":"test","script":{"type":"text/javascript","exec":["// CREDIT_SOURCES doesn't include IN_APP_SPEND. Decision 1.4 + 2.2.","pm.test('422',()=>pm.response.to.have.status(422));"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{system_jwt_service}}"},{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"k-scn-f4-{{$timestamp}}"}],"body":{"mode":"raw","raw":"{\"userId\":\"{{alice_user_id}}\",\"amountCents\":100,\"source\":\"IN_APP_SPEND\",\"externalRef\":\"f4\"}"},"url":{"raw":"{{wallet_url}}/api/wallet/credit","host":["{{wallet_url}}"],"path":["api","wallet","credit"]}}}
      ]
    },
    {
      "name": "G. Adversarial input",
      "item": [
