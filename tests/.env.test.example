# Test environment variables for .NET endpoint testing
# Copy this file to .env.test and fill in your values.
# Never commit .env.test — it contains secrets.
JWT_SECRET=your-jwt-secret-here
POST_DB_PASSWORD=your-post-db-password
SOCIAL_DB_PASSWORD=your-social-db-password
MONGO_PASSWORD=test-mongo-password
BUNDLE_DB_PASSWORD=your-bundle-db-password
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
CLOUDINARY_URL=cloudinary://your-api-key:your-api-secret@your-cloud-name
